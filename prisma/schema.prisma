generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Control {
  id          String                 @id @default(cuid())
  framework   String
  control_ref String
  description String
  embedding   Unsupported("vector")?
  created_at  DateTime?              @default(now()) @db.Timestamptz(6)
  violations  Violation[]

  @@map("controls")
}

model AuditEvent {
  id         String      @id @default(cuid())
  raw_output String
  source     String?
  created_at DateTime?   @default(now()) @db.Timestamptz(6)
  violations Violation[]

  @@map("audit_events")
}

model Violation {
  id                 String      @id @default(cuid())
  audit_event_id     String?
  violation_type     String
  severity           String
  rationale          String
  matched_control_id String?
  created_at         DateTime?   @default(now()) @db.Timestamptz(6)
  audit_events       AuditEvent? @relation(fields: [audit_event_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  controls           Control?    @relation(fields: [matched_control_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("violations")
}

model RiskRegister {
  id          String    @id @default(cuid())
  category    String
  description String
  status      String
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  @@map("risk_register")
}
